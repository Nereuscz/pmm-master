# AI (povinné pro zpracování)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# Embeddings pro RAG (volitelné – bez něj lexikální fallback)
OPENAI_API_KEY=

# Databáze (povinné)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Tavily – tržní výzkum (volitelné)
TAVILY_API_KEY=

# Asana OAuth – přihlášení + export
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=
ASANA_BASE_URL=https://app.asana.com/api/1.0

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Rate limiting (volitelné – bez nastavení se limit neaplikuje)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Cron – ověření pro týdenní Asana sync (POST /api/asana/sync)
# Nastav pro produkci; cron request musí mít hlavičku: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
